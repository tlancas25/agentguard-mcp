# AgentGuard Configuration File
# Copy to agentguard.yaml and customize for your environment.
# Environment variables override these values when set.

# -------------------------------------------------------------------
# Core Settings
# -------------------------------------------------------------------

# Operating mode: "dev" (permissive, log-only) or "federal" (strict enforcement)
mode: dev

# Path to SQLite audit database. Tildes and $VARS are expanded.
# The default (~/.agentguard/audit.db) keeps the log in one known place
# regardless of which directory agentguard is launched from. Override by
# setting this key or the AGENTGUARD_AUDIT_DB env var.
audit_db_path: ~/.agentguard/audit.db

# Log level: DEBUG | INFO | WARNING | ERROR
log_level: INFO

# Ed25519 private key (base64-encoded) for tamper-evident audit signatures.
# Leave empty in dev mode. Required for federal mode.
# Generate with: agentguard init --gen-key
signing_key: ""

# -------------------------------------------------------------------
# Upstream MCP Servers (servers AgentGuard protects)
# -------------------------------------------------------------------
upstream_servers: []
  # With an empty list AgentGuard runs as a no-op stdio server that still
  # logs session_start events. Uncomment an entry below to put a real
  # MCP server behind AgentGuard.
  #
  # - name: filesystem
  #   transport: stdio
  #   command: uvx
  #   args: ["mcp-server-filesystem", "~/Documents/Projects"]
  #   policy_override: ""
  #
  # - name: github
  #   transport: http
  #   url: http://localhost:3001
  #   headers:
  #     Authorization: "Bearer ${GITHUB_TOKEN}"

# -------------------------------------------------------------------
# Policy Bundles (evaluated in order, first match wins)
# -------------------------------------------------------------------
policy_bundles: []
  # Empty list is valid in dev mode (log everything, block nothing).
  # Point at absolute YAML paths when you want explicit allow/deny rules.

# -------------------------------------------------------------------
# Federal Mode Settings (ignored in dev mode)
# -------------------------------------------------------------------
federal:
  agency_id: ""           # e.g., "DOD-DISA"
  system_name: ""         # e.g., "MySystem ATO Package"
  impact_level: MODERATE  # LOW | MODERATE | HIGH
  # Require all audit events to be signed
  require_signing: true
  # SIEM export endpoint (optional)
  siem_endpoint: ""
  siem_api_key: ""

# -------------------------------------------------------------------
# Detection Settings
# -------------------------------------------------------------------
detectors:
  prompt_injection:
    enabled: false   # Set true in federal mode
    score_threshold: 0.7
  pii:
    enabled: false   # Set true in federal mode
    action: log      # log | deny
  secrets:
    enabled: true    # Enabled in both modes (catches accidental leaks)
    action: log
  tool_poisoning:
    enabled: true    # Scan tool descriptions on startup
    action: log
