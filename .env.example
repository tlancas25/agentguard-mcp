# AgentGuard Configuration
AGENTGUARD_MODE=dev           # dev | federal
AGENTGUARD_CONFIG=./agentguard.yaml
AGENTGUARD_AUDIT_DB=./audit.db
AGENTGUARD_LOG_LEVEL=INFO

# Downstream MCP servers to protect
AGENTGUARD_UPSTREAM_SERVERS=./upstream.yaml

# Optional: Ed25519 signing key for tamper-evident audit
# Generate with: agentguard init --gen-key
AGENTGUARD_SIGNING_KEY=

# Federal Mode only
AGENTGUARD_AGENCY_ID=
AGENTGUARD_SYSTEM_NAME=
AGENTGUARD_IMPACT_LEVEL=MODERATE    # LOW | MODERATE | HIGH
